# Copy this file to .env and fill in your values
# Never commit .env to version control

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# GitHub backend (set STORAGE_BACKEND=github to use)
# GITHUB_TOKEN is required. Owner and repo are auto-detected from
# `git remote get-url origin` — only set them to override.
GITHUB_TOKEN=
# GITHUB_OWNER=          # optional override
# GITHUB_RUNS_REPO=      # optional override
STORAGE_BACKEND=azure
