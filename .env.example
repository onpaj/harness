# Copy this file to .env and fill in your values
# Never commit .env to version control

# Azure backend credentials (required when storage_backend = "azure" in config.json)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net

# GitHub backend credentials (required when storage_backend = "github" in config.json)
# Owner and repo are auto-detected from `git remote get-url origin` — only set to override.
GITHUB_TOKEN=
# GITHUB_OWNER=          # optional override
# GITHUB_RUNS_REPO=      # optional override
